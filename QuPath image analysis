// ====== Export per-cell (CSV with UTF-8 BOM) ======
def exportAllChannelsPerCell = { boolean processAll, String onlyName ->
    String imageName = getProjectEntry()?.getImageName() ?: getCurrentImageData().getServer().getShortServerName()
    File outFile
    def project = getProject()
    if (project != null) {
        def outDir = buildFilePath(PROJECT_BASE_DIR, 'exports'); mkdirs(outDir)
        outFile = new File(outDir, "${imageName}_per_cell_allchannels.csv")
    } else {
        outFile = new File(System.getProperty('user.home'), "${imageName}_per_cell_allchannels.csv")
    }

    def bases = getBases(processAll, onlyName)
    def pw = makeCsvWriter(outFile)

    def server = getCurrentImageData().getServer()
    def cal    = server.getPixelCalibration()
    double umPerPx = (cal == null) ? 1.0 : cal.getAveragedPixelSizeMicrons()
    double um2PerPx2 = umPerPx * umPerPx
    def areaUm2 = { roi -> (roi == null) ? Double.NaN : (roi.getArea() * um2PerPx2) }
    def equivDiamUm = { aUm2 -> (Double.isFinite(aUm2) && aUm2 > 0.0) ? 2.0*Math.sqrt(aUm2/Math.PI) : Double.NaN }

    pw.println("BaseAnnotation,Source,Index,CentroidX,CentroidY,CentroidZ,H_flag,PI_flag,CAL_flag,category7,tripleClass,R_PI_mean,G_CAL_mean,B_HOE_mean,H_area_um2,H_equiv_diam_um,PI_area_um2,PI_equiv_diam_um,CAL_area_um2,CAL_equiv_diam_um,H_partners_PI_n,H_partners_CAL_n,H_triple_pairs_n,H_partners_PI_ids,H_partners_CAL_ids")

    bases.each { baseAnn ->
        def annH = findClone(baseAnn, 'Hoechst')
        def annP = findClone(baseAnn, 'PI')
        def annC = findClone(baseAnn, 'Calcein')

        def hCells = (annH ? getDetectionObjects().findAll { it.getParent() == annH && it.hasROI() } : [])
        def pCells = (annP ? getDetectionObjects().findAll { it.getParent() == annP && it.hasROI() } : [])
        def cCells = (annC ? getDetectionObjects().findAll { it.getParent() == annC && it.hasROI() } : [])

        int idxH = 0
        hCells.each { h ->
            idxH++
            def hROI = h.getROI()
            def pCands = pCells.collect { p -> [p, areaOf(RoiTools.combineROIs(hROI, p.getROI(), RoiTools.CombineOp.INTERSECT))] }
                               .findAll { it[1] > 0.0 }
            def cCands = cCells.collect { c -> [c, areaOf(RoiTools.combineROIs(hROI, c.getROI(), RoiTools.CombineOp.INTERSECT))] }
                               .findAll { it[1] > 0.0 }

            def pBest = pCands.isEmpty() ? null : pCands.max{ it[1] }[0]
            def cBest = cCands.isEmpty() ? null : cCands.max{ it[1] }[0]

            boolean overlapsP = pBest != null
            boolean overlapsC = cBest != null

            Double clsNum = mval(h.getMeasurementList(), "Triple overlap class")
            String tclass = (clsNum == 1.0) ? "Single" : (clsNum == 2.0 ? "Several" : (clsNum == 0.0 ? "None" : ""))

            String cat =
                overlapsP && overlapsC ? "H + PI + CAL" :
                overlapsP && !overlapsC ? "H + PI" :
                !overlapsP && overlapsC ? "H + CAL" : "H only"

            double R = overlapsP ? mval(pBest.getMeasurementList(), KEY_R) : Double.NaN
            double G = overlapsC ? mval(cBest.getMeasurementList(), KEY_G) : Double.NaN
            double B = mval(h.getMeasurementList(), KEY_B)

            double aH = areaUm2(hROI)
            double dH = equivDiamUm(aH)

            pw.println([
                baseAnn.getName(), "H", idxH,
                hROI.getCentroidX(), hROI.getCentroidY(), centroidZSafe(hROI),
                1, overlapsP ? 1 : 0, overlapsC ? 1 : 0,
                cat, tclass,
                R, G, B,
                aH, dH, "", "", "", "",
                mval(h.getMeasurementList(), "H partners PI (n)"),
                mval(h.getMeasurementList(), "H partners CAL (n)"),
                mval(h.getMeasurementList(), "H triple pairs (n)"),
                '"' + ((h.getMeasurementList()?.get("H partners PI ids")  ?: "") as String).replace('"','""') + '"',
                '"' + ((h.getMeasurementList()?.get("H partners CAL ids") ?: "") as String).replace('"','""') + '"'
            ].join(","))
        }

        def pNoH = pCells.findAll { p -> !hCells.any { h -> areaOf(RoiTools.combineROIs(h.getROI(), p.getROI(), RoiTools.CombineOp.INTERSECT)) > 0.0 } }
        def cNoH = cCells.findAll { c -> !hCells.any { h -> areaOf(RoiTools.combineROIs(h.getROI(), c.getROI(), RoiTools.CombineOp.INTERSECT)) > 0.0 } }

        def usedP = new HashSet()
        def usedC = new HashSet()
        int idxP = 0, idxC = 0, idxPair = 0

        pNoH.each { p ->
            if (usedP.contains(p)) return
            def pROI = p.getROI()
            def cCands = cNoH.findAll { c -> !usedC.contains(c) && areaOf(RoiTools.combineROIs(pROI, c.getROI(), RoiTools.CombineOp.INTERSECT)) > 0.0 }
            if (!cCands.isEmpty()) {
                def bestC = null; double bestA = -1
                cCands.each { c -> double a = areaOf(RoiTools.combineROIs(pROI, c.getROI(), RoiTools.CombineOp.INTERSECT)); if (a > bestA) { bestA = a; bestC = c } }
                usedP.add(p); usedC.add(bestC); idxPair++

                double cx = (pROI.getCentroidX() + bestC.getROI().getCentroidX()) / 2.0
                double cy = (pROI.getCentroidY() + bestC.getROI().getCentroidY()) / 2.0
                Double z1 = zFromROI(pROI); Double z2 = zFromROI(bestC.getROI())
                String cz = (z1 != null && z2 != null) ? ("" + ((z1 + z2)/2.0)) : ""

                double R = mval(p.getMeasurementList(), KEY_R)
                double G = mval(bestC.getMeasurementList(), KEY_G)

                double aP = areaUm2(pROI), dP = equivDiamUm(aP)
                double aC = areaUm2(bestC.getROI()), dC = equivDiamUm(aC)

                pw.println([ baseAnn.getName(), "PI+CAL(no H)", idxPair,
                             cx, cy, cz, 0, 1, 1, "PI + CAL", "",
                             R, G, "",
                             "", "",
                             aP, dP,
                             aC, dC,
                             "", "", "", "", ""
                ].join(","))
            }
        }

        pNoH.findAll { !usedP.contains(it) }.each { p ->
            idxP++
            def r = p.getROI()
            double R = mval(p.getMeasurementList(), KEY_R)
            double aP = areaUm2(r), dP = equivDiamUm(aP)

            pw.println([ baseAnn.getName(), "PI", idxP,
                         r.getCentroidX(), r.getCentroidY(), centroidZSafe(r),
                         0, 1, 0, "PI only", "",
                         R, "", "",
                         "", "",
                         aP, dP,
                         "", "",
                         "", "", "", "", ""
            ].join(","))
        }

        cNoH.findAll { !usedC.contains(it) }.each { c ->
            idxC++
            def r = c.getROI()
            double G = mval(c.getMeasurementList(), KEY_G)
            double aC = areaUm2(r), dC = equivDiamUm(aC)

            pw.println([ baseAnn.getName(), "CAL", idxC,
                         r.getCentroidX(), r.getCentroidY(), centroidZSafe(r),
                         0, 0, 1, "CAL only", "",
                         "", G, "",
                         "", "",
                         "", "",
                         aC, dC,
                         "", "", "", "", ""
            ].join(","))
        }
    }

    pw.flush(); pw.close()
    println "INFO: Wrote ALL-channel CSV (RGB + size): ${outFile.getAbsolutePath()}"
}
exportAllChannelsPerCell(PROCESS_ALL_ANNOTATIONS, ONLY_ANN_NAME)


// ====== Export ALL detections' sizes (separate CSV; one row per detection) ======
def exportAllDetectionSizesSimple = { boolean processAll, String onlyName ->
    String imageName = getProjectEntry()?.getImageName() ?: getCurrentImageData().getServer().getShortServerName()
    File outFile
    def project = getProject()
    if (project != null) {
        def outDir = buildFilePath(PROJECT_BASE_DIR, 'exports'); mkdirs(outDir)
        outFile = new File(outDir, "${imageName}_all_detections_sizes.csv")
    } else {
        outFile = new File(System.getProperty('user.home'), "${imageName}_all_detections_sizes.csv")
    }

    // pixel→µm helpers (same calibration used elsewhere)
    def server = getCurrentImageData().getServer()
    def cal    = server.getPixelCalibration()
    double umPerPx    = (cal == null) ? 1.0 : cal.getAveragedPixelSizeMicrons()
    double um2PerPx2  = umPerPx * umPerPx
    def areaUm2       = { roi -> (roi == null) ? Double.NaN : (roi.getArea() * um2PerPx2) }
    def equivDiamUm   = { aUm2 -> (Double.isFinite(aUm2) && aUm2 > 0.0) ? 2.0 * Math.sqrt(aUm2 / Math.PI) : Double.NaN }
    def zSafe         = { roi -> try { def z = roi?.getZ(); z == null ? "" : ("" + (z as double)) } catch (Throwable t) { "" } }

    def pw = makeCsvWriter(outFile)
    pw.println("BaseAnnotation,Source,Index,CentroidX,CentroidY,CentroidZ,Area_um2,Equiv_diam_um")

    // Which annotations to use
    def bases = getAnnotationObjects().findAll{ it.hasROI() }
    if (!processAll) {
        def a = bases.find{ it.getName() == onlyName }
        bases = a ? [a] : []
    }

    bases.each { baseAnn ->
        // find the three clones created earlier
        def annH = findClone(baseAnn, 'Hoechst')
        def annP = findClone(baseAnn, 'PI')
        def annC = findClone(baseAnn, 'Calcein')

        def detsH = (annH ? getDetectionObjects().findAll { it.getParent() == annH && it.hasROI() } : [])
        def detsP = (annP ? getDetectionObjects().findAll { it.getParent() == annP && it.hasROI() } : [])
        def detsC = (annC ? getDetectionObjects().findAll { it.getParent() == annC && it.hasROI() } : [])

        int iH = 0; detsH.each { d ->
            iH++
            def r = d.getROI()
            double a = areaUm2(r)
            double e = equivDiamUm(a)
            pw.println([ baseAnn.getName(), "H", iH, r.getCentroidX(), r.getCentroidY(), zSafe(r), a, e ].join(","))
        }

        int iP = 0; detsP.each { d ->
            iP++
            def r = d.getROI()
            double a = areaUm2(r)
            double e = equivDiamUm(a)
            pw.println([ baseAnn.getName(), "PI", iP, r.getCentroidX(), r.getCentroidY(), zSafe(r), a, e ].join(","))
        }

        int iC = 0; detsC.each { d ->
            iC++
            def r = d.getROI()
            double a = areaUm2(r)
            double e = equivDiamUm(a)
            pw.println([ baseAnn.getName(), "CAL", iC, r.getCentroidX(), r.getCentroidY(), zSafe(r), a, e ].join(","))
        }
    }

    pw.flush(); pw.close()
    println "INFO: Wrote ALL-detection sizes CSV: ${outFile.getAbsolutePath()}"
}

// Call the new export (does not affect your existing exports)
exportAllDetectionSizesSimple(PROCESS_ALL_ANNOTATIONS, ONLY_ANN_NAME)


