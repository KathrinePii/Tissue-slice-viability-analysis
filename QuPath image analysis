def pickMean = { ml, String colorWord ->
    def names = ml?.getMeasurementNames()
    if (names == null) return Double.NaN
    def key = names.find { k ->
        def s = (k ?: "").toLowerCase()
        s.contains('mean') && (s.contains(colorWord))
    }
    return (key && (ml.get(key) instanceof Number)) ? (ml.get(key) as double) : Double.NaN
}

// ---------- Measure & stamp helper (per-cell) ----------
def measureAndStamp = { ann, String channelName, String outKey ->
    if (ann == null) return 0
    def dets = getDetectionObjects().findAll { it.getParent() == ann }
    if (dets.isEmpty()) { println "WARN: No detections under '${ann?.getName()}' to measure."; return 0 }

    resetSelection(); selectObjects(dets)

    boolean ok = runIntensityPluginPortable(channelName)
    if (!ok) {
        dets.each { d -> d.getMeasurementList().put(outKey, Double.NaN) }
        println "WARN: Stamped NaN for '${outKey}' because intensity plugin didn’t accept any payload."
        return dets.size()
    }

    int stamped = 0
    dets.each { d ->
        def ml = d.getMeasurementList()
        def key = ml.getMeasurementNames()?.find { k ->
            def s = (k?:'').toLowerCase()
            s.contains(channelName.toLowerCase()) && (s.contains(' mean') || s.startsWith('mean') || s.contains('avg'))
        }
        double val = (key ? ((ml.get(key) instanceof Number) ? (ml.get(key) as double) : Double.NaN) : Double.NaN)
        ml.put(outKey, val)
        stamped++
    }
    println "INFO: Stamped '${outKey}' on ${stamped} detections under '${ann.getName()}' (region=${REGION_FOR_INTENSITY})."
    return stamped
}

