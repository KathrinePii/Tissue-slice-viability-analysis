// ---------- helpers ----------
def argb = { int r,int g,int b -> (0xFF<<24)|((r&0xFF)<<16)|((g&0xFF)<<8)|(b&0xFF) }

def makeCsvWriter = { File outFile ->
    def fos = new FileOutputStream(outFile)
    def osw = new OutputStreamWriter(fos, StandardCharsets.UTF_8)
    def pw  = new PrintWriter(osw)
    pw.write('\ufeff') // UTF-8 BOM
    return pw
}

def createOrReplaceClone = { baseAnn, String suffix ->
    String newName = baseAnn.getName() + " — " + suffix
    if (REPLACE_EXISTING_CLONES) {
        def old = getAnnotationObjects().find { (it.getName() ?: "") == newName }
        if (old) removeObjectAndDescendants(old)
    }
    def clone = PathObjects.createAnnotationObject(baseAnn.getROI(), baseAnn.getPathClass())
    clone.setName(newName)
    addObject(clone)
    clone
}
def clearDetectionsUnder = { ann ->
    def kids = getDetectionObjects().findAll { it.getParent() == ann }
    if (!kids.isEmpty()) { removeObjects(kids); fireHierarchyUpdate() }
}
def channelExists = { String name ->
    def chans = getCurrentImageData().getServer().getMetadata().getChannels()*.getName()
    chans.any{ (it ?: "").equalsIgnoreCase(name) }
}
def runWatershedIntoClone = { cloneAnn, String channel, double thr, targetClass, String tag ->
    if (!channelExists(channel)) { println "WARN: Channel '" + channel + "' not found. Skipping " + tag + "."; return 0 }
    if (CLEAR_DETECTIONS_IN_EACH_CLONE) clearDetectionsUnder(cloneAnn)
    resetSelection(); selectObjects(cloneAnn)
    String json =
        '{' +
        '"detectionImage":"' + channel + '",' +
        '"requestedPixelSizeMicrons":' + REQ_PX + ',' +
        '"backgroundRadiusMicrons":'    + BG_RAD + ',' +
        '"backgroundByReconstruction":true,' +
        '"medianRadiusMicrons":'         + MED_RAD + ',' +
        '"sigmaMicrons":'                + SIGMA + ',' +
        '"minAreaMicrons":'              + MIN_AREA + ',' +
        '"maxAreaMicrons":'              + MAX_AREA + ',' +
        '"threshold":'                   + thr + ',' +
        '"watershedPostProcess":true,' +
        '"cellExpansionMicrons":'        + CELL_EXP + ',' +
        '"includeNuclei":true,' +
        '"smoothBoundaries":true,' +
        '"makeMeasurements":true' +
        '}'
    try {
        runPlugin('qupath.imagej.detect.cells.WatershedCellDetection', json)
    } catch (Throwable t1) {
        try { runPlugin('qupath.imagej.detect.nuclei.WatershedCellDetection', json) }
        catch (Throwable t2) { println "ERROR: Could not run WatershedCellDetection for '" + channel + "'."; return 0 }
    }
    int nTagged = 0
    getDetectionObjects().each { d ->
        if (d.getParent() == cloneAnn) { d.setPathClass(targetClass); d.setColor(null); nTagged++ }
    }
    fireHierarchyUpdate()
    println "Cell detection (" + tag + ") -> clone '" + cloneAnn.getName() + "': tagged=" + nTagged + "."
    nTagged
}
def areaOf = { roi -> (roi == null) ? 0.0 : roi.getArea() }
def expandSafe = { roi, double amount ->
    if (roi == null || amount == 0.0) return roi
    try { return RoiTools.expand(roi, amount) } catch (Throwable t) { return roi }
}
def findClone = { baseAnn, String suffix ->
    def expect = [ baseAnn.getName() + " — " + suffix, baseAnn.getName() + " - "  + suffix ] as Set
    getAnnotationObjects().find { a -> expect.contains(a.getName() ?: "") }
}
def mval = { ml, String key ->
    try {
        def v = ml?.get(key)
        return (v instanceof Number) ? (v as double) : Double.NaN
    } catch (Throwable t) {
        return Double.NaN
    }
}
def zFromROI = { roi -> try { def z = roi == null ? null : roi.getZ(); return z == null ? null : (z as double) } catch (Throwable t) { return null } }
def centroidZSafe = { roi -> def z = zFromROI(roi); return z == null ? "" : ("" + z) }
def getBases = { boolean processAll, String onlyName ->
    def bases = getAnnotationObjects().findAll { it.hasROI() }
    if (!processAll) { def a = bases.find { it.getName() == onlyName }; if (a != null) bases = [a] }
    bases
}

// ---------- CLEAR PREVIOUS RUN ----------
def clearPreviousRun = { boolean processAll, String onlyName, boolean alsoClearBase ->
    def suffixes = ['Hoechst','PI','Calcein']
    int removedClones = 0, removedPoints = 0, removedBaseDet = 0
    def bases = getBases(processAll, onlyName)
    bases.each { base ->
        def cloneNames = suffixes.collectMany { suf -> [ base.getName() + " — " + suf, base.getName() + " - " + suf ] }
        def clones = getAnnotationObjects().findAll { cloneNames.contains(it.getName() ?: "") }
        if (!clones.isEmpty()) { clones.each { removeObjectAndDescendants(it) }; removedClones += clones.size() }
        def points = getAnnotationObjects().findAll { obj ->
            def nm = (obj.getName() ?: "")
            nm.startsWith("H ") || nm.startsWith("P ") || nm.startsWith("C ") || nm.startsWith("Triple ")
        }
        if (!points.isEmpty()) { removeObjects(points); removedPoints += points.size() }
        if (alsoClearBase) {
            def baseDets = getDetectionObjects().findAll { it.getParent() == base }
            if (!baseDets.isEmpty()) { removeObjects(baseDets); removedBaseDet += baseDets.size() }
        }
        try {
            def ml = base.getMeasurementList()
            ['Triple overlap - Hoechst cells (n)','Triple overlap - Single cell count','Triple overlap - Several cell count',
             'Triple overlap - No triple count','Triple overlap - Single cell %','Triple overlap - Several cell %'].each { k -> ml.remove(k) }
        } catch (Throwable ignore) {}
        def oldTiles = getAnnotationObjects().findAll { (it.getName() ?: "").startsWith(base.getName() + " — Tile") }
        if (!oldTiles.isEmpty()) removeObjects(oldTiles)
    }
    fireHierarchyUpdate()
    println "INFO: CLEANUP: removed clones=" + removedClones + ", points=" + removedPoints + ", baseDetections=" + removedBaseDet + "."
}
if (CLEAR_PREVIOUS_RUN) clearPreviousRun(PROCESS_ALL_ANNOTATIONS, ONLY_ANN_NAME, ALSO_CLEAR_BASE_DETECTIONS)

// ---------- Intensity plugin for per-cell stamping ----------
def runIntensityPluginPortable = { String channelName ->
    def candidates = [
        'qupath.lib.plugins.objects.IntensityFeaturesPlugin',
        'qupath.lib.plugins.IntensityFeaturesPlugin',
        'qupath.lib.algorithms.IntensityFeaturesPlugin'
    ]

    def base = '"pixelSizeMicrons":' + REQ_PX + ',' +
               '"region":"' + REGION_FOR_INTENSITY + '",' +
               '"tileSizeMicrons":25.0,' +
               '"doMean":true,"doMinMax":false,"doStdDev":false,"doMedian":false'

    def payloadsFor = { ch ->
        [
            '{' + base + ',"channels":"' + ch + '"}',
            '{' + base + ',"channel":"'  + ch + '"}',
            '{' + base + ',"channels":[{"channel":"' + ch + '","normalize":false}]}'
        ]
    }

    for (cid in candidates) {
        boolean exists = false
        try { Class.forName(cid); exists = true } catch (Throwable ignore) {}
        if (!exists) continue
        for (payload in payloadsFor(channelName)) {
            try {
                runPlugin(cid, payload)
                println "INFO: Ran intensity plugin '" + cid + "' with payload shape OK"
                return true
            } catch (Throwable t) { /* try next */ }
        }
    }
    println "ERROR: No compatible IntensityFeaturesPlugin payload worked for channel '" + channelName + "'."
    return false
}

