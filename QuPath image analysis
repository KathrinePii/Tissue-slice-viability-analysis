// ====== Triple-overlap analysis (colorize Hoechst) ======
def computeTripleOverlap = { boolean processAll, String onlyName ->
    def safeId = { obj ->
        try { return obj?.getID() } catch (Throwable t) {}
        try {
            def r = obj?.getROI()
            return r ? ("cx="+Math.rint(r.getCentroidX())+",cy="+Math.rint(r.getCentroidY())) : ("obj@"+System.identityHashCode(obj))
        } catch (Throwable t2) { return ("obj@"+System.identityHashCode(obj)) }
    }

    def bases = getBases(processAll, onlyName)
    bases.each { baseAnn ->
        def annH = findClone(baseAnn, 'Hoechst')
        def annP = findClone(baseAnn, 'PI')
        def annC = findClone(baseAnn, 'Calcein')
        if (!annH || !annP || !annC) { println "WARN: Missing clones under '${baseAnn.getName()}'. Skipping triple."; return }

        def hCells = getDetectionObjects().findAll { it.getParent() == annH && it.hasROI() }
        def pCells = getDetectionObjects().findAll { it.getParent() == annP && it.hasROI() }
        def cCells = getDetectionObjects().findAll { it.getParent() == annC && it.hasROI() }

        int singleCount = 0, multiCount = 0, noTripleCount = 0

        hCells.each { h ->
            def hROI = h.getROI()
            double aH = areaOf(hROI)

            // candidates with any intersection
            def pCands0 = pCells.findAll { p -> areaOf(RoiTools.combineROIs(hROI, p.getROI(), RoiTools.CombineOp.INTERSECT)) > 0.0 }
            def cCands0 = cCells.findAll { c -> areaOf(RoiTools.combineROIs(hROI, c.getROI(), RoiTools.CombineOp.INTERSECT)) > 0.0 }

            def hDil = (H_DILATE_FOR_TRIPLE != 0.0) ? expandSafe(hROI, H_DILATE_FOR_TRIPLE) : hROI

            // filter partners by min H overlap fraction
            def piPartners  = [] as Set
            def calPartners = [] as Set

            pCands0.each { p ->
                def pUse  = expandSafe(p.getROI(), -ERODE_PI_BEFORE_TRIPLE)
                def pNear = (hDil != null && pUse != null) ? RoiTools.combineROIs(pUse, hDil, RoiTools.CombineOp.INTERSECT) : pUse
                if (pNear != null) {
                    if (MIN_H_PI_FRAC > 0.0 && aH > 0) {
                        def h_pi = RoiTools.combineROIs(hROI, pNear, RoiTools.CombineOp.INTERSECT)
                        if (areaOf(h_pi)/aH >= MIN_H_PI_FRAC) piPartners << p
                    } else {
                        piPartners << p
                    }
                }
            }
            cCands0.each { c ->
                def cUse  = expandSafe(c.getROI(), -ERODE_CAL_BEFORE_TRIPLE)
                def cNear = (hDil != null && cUse != null) ? RoiTools.combineROIs(cUse, hDil, RoiTools.CombineOp.INTERSECT) : cUse
                if (cNear != null) {
                    if (MIN_H_CAL_FRAC > 0.0 && aH > 0) {
                        def h_cal = RoiTools.combineROIs(hROI, cNear, RoiTools.CombineOp.INTERSECT)
                        if (areaOf(h_cal)/aH >= MIN_H_CAL_FRAC) calPartners << c
                    } else {
                        calPartners << c
                    }
                }
            }

            // triple pairs & best max fraction (for coloring/class)
            double bestMaxFrac = Double.NaN
            int triplePairs = 0

            if (!piPartners.isEmpty() && !calPartners.isEmpty()) {
                piPartners.each { p ->
                    def pUse  = expandSafe(p.getROI(), -ERODE_PI_BEFORE_TRIPLE)
                    def pNear = (hDil != null && pUse != null) ? RoiTools.combineROIs(pUse, hDil, RoiTools.CombineOp.INTERSECT) : pUse
                    double aP = areaOf(pUse)
                    calPartners.each { c ->
                        def cUse  = expandSafe(c.getROI(), -ERODE_CAL_BEFORE_TRIPLE)
                        def cNear = (hDil != null && cUse != null) ? RoiTools.combineROIs(cUse, hDil, RoiTools.CombineOp.INTERSECT) : cUse
                        double aC = areaOf(cUse)
                        if (pNear == null || cNear == null) return
                        def interPC = RoiTools.combineROIs(pNear, cNear, RoiTools.CombineOp.INTERSECT)
                        if (areaOf(interPC) <= 0) return

                        def interAll = RoiTools.combineROIs(RoiTools.combineROIs(hROI, pNear, RoiTools.CombineOp.INTERSECT), cNear, RoiTools.CombineOp.INTERSECT)
                        double aI = areaOf(interAll)
                        if (aI <= 0) return

                        triplePairs++
                        double fH = (aH > 0) ? (aI / aH) : Double.NaN
                        double fP = (aP > 0) ? (aI / aP) : Double.NaN
                        double fC = (aC > 0) ? (aI / aC) : Double.NaN
                        double maxFrac = Math.max((Double.isNaN(fH)?0.0:fH), Math.max((Double.isNaN(fP)?0.0:fP), (Double.isNaN(fC)?0.0:fC)))
                        if (Double.isNaN(bestMaxFrac) || maxFrac > bestMaxFrac) bestMaxFrac = maxFrac
                    }
                }
            }

            boolean hasAnyTriple = (triplePairs > 0) || !Double.isNaN(bestMaxFrac)
            boolean isSingle     = hasAnyTriple && (bestMaxFrac >= TRIPLE_MAXFRAC_SINGLE_THRESHOLD)

            if (COLORIZE_HOECHST_BY_TRIPLE_CLASS) {
                h.setColor(!hasAnyTriple ? COLOR_H_NONE : (isSingle ? COLOR_H_SINGLE : COLOR_H_SEVERAL))
            }
            if (CHANGE_CLASS_INSTEAD_OF_COLOR) {
                h.setPathClass(!hasAnyTriple ? clsTripleNone : (isSingle ? clsTripleSingle : clsTripleSeveral))
            }

            // stamp measurements
            def ml = h.getMeasurementList()
            ml.put('Triple overlap max frac (max)',   hasAnyTriple ? bestMaxFrac : Double.NaN)
            ml.put('Triple overlap class',            hasAnyTriple ? (isSingle ? 1.0 : 2.0) : 0.0)

            def piIDs  = piPartners.collect { safeId(it) } as List
            def calIDs = calPartners.collect { safeId(it) } as List
            ml.put('H partners PI (n)',  (double)piIDs.size())
            ml.put('H partners CAL (n)', (double)calIDs.size())
            ml.put('H triple pairs (n)', (double)triplePairs)
            try { ml.put('H partners PI ids',  piIDs.join(';')) } catch (Throwable ignore) {}
            try { ml.put('H partners CAL ids', calIDs.join(';')) } catch (Throwable ignore) {}

            if (!hasAnyTriple)       noTripleCount++
            else if (isSingle)       singleCount++
            else                     multiCount++
        }

        def mlb = baseAnn.getMeasurementList()
        int n = getDetectionObjects().count { it.getParent() == findClone(baseAnn,'Hoechst') && it.hasROI() }
        mlb.put('Triple overlap - Hoechst cells (n)', (double)n)
        mlb.put('Triple overlap - Single cell count', (double)singleCount)
        mlb.put('Triple overlap - Several cell count', (double)multiCount)
        mlb.put('Triple overlap - No triple count', (double)noTripleCount)
        mlb.put('Triple overlap - Single cell %', n>0 ? 100.0*singleCount/n : Double.NaN)
        mlb.put('Triple overlap - Several cell %', n>0 ? 100.0*multiCount/n : Double.NaN)

        println String.format(
            "INFO: Triple '%s': single=%d (%.1f%%), several=%d (%.1f%%), none=%d (n=%d)",
            baseAnn.getName(),
            singleCount, (n > 0 ? 100.0*singleCount/n : Double.NaN),
            multiCount,  (n > 0 ? 100.0*multiCount/n  : Double.NaN),
            noTripleCount, n
        )
    }
    fireHierarchyUpdate()
}
computeTripleOverlap(PROCESS_ALL_ANNOTATIONS, ONLY_ANN_NAME)

// ====== TILES — create, count, filter (area-normalized), unions, BG means & intensity ratios ======
def createTilesAndFilter = { baseAnn ->
    def imgData = getCurrentImageData()
    def server  = imgData.getServer()
    def cal     = server.getPixelCalibration()
    double umPerPx = (cal == null) ? 1.0 : cal.getAveragedPixelSizeMicrons()
    double tileWpx = Math.max(1.0, TILE_SIZE_UM / umPerPx)
    double tileHpx = Math.max(1.0, TILE_SIZE_UM / umPerPx)
    double fullTileAreaUm2 = TILE_SIZE_UM * TILE_SIZE_UM

    def bROI = baseAnn.getROI()
    double bx = bROI.getBoundsX(), by = bROI.getBoundsY()
    double bw = bROI.getBoundsWidth(), bh = bROI.getBoundsHeight()

    double x0 = Math.max(0, Math.floor(bx))
    double y0 = Math.max(0, Math.floor(by))
    double x1 = Math.min(server.getWidth(),  Math.ceil(bx + bw))
    double y1 = Math.min(server.getHeight(), Math.ceil(by + bh))

    // remove old tiles
    def oldTiles = getAnnotationObjects().findAll { (it.getName() ?: "").startsWith(baseAnn.getName() + " — Tile") }
    if (!oldTiles.isEmpty()) removeObjects(oldTiles)

    def annH = findClone(baseAnn, 'Hoechst')
    def annP = findClone(baseAnn, 'PI')
    def annC = findClone(baseAnn, 'Calcein')

    def hCells = (annH ? getDetectionObjects().findAll { it.getParent() == annH && it.hasROI() } : [])
    def pCells = (annP ? getDetectionObjects().findAll { it.getParent() == annP && it.hasROI() } : [])
    def cCells = (annC ? getDetectionObjects().findAll { it.getParent() == annC && it.hasROI() } : [])

    def tiles = []

    // --- Build grid of tiles, but CLIPPED to the annotation ROI (works for polygon/brush) ---
    for (double y = y0; y < y1; y += tileHpx) {
        double h = Math.min(tileHpx, y1 - y); if (h <= 0) break
        for (double x = x0; x < x1; x += tileWpx) {
            double w = Math.min(tileWpx, x1 - x); if (w <= 0) break

            // 1) Start with the rectangular candidate tile
            def rectROI = ROIs.createRectangleROI(x, y, w, h, ImagePlane.getDefaultPlane())

            // 2) Intersect with your annotation ROI (polygon / brush / whatever)
            def clippedROI = RoiTools.combineROIs(rectROI, bROI, RoiTools.CombineOp.INTERSECT)

            // 3) Skip tiles that don't overlap the annotation at all
            if (clippedROI == null || clippedROI.getArea() <= 0.0)
                continue

            // 4) Use the CLIPPED ROI as the tile geometry
            def tile = PathObjects.createAnnotationObject(clippedROI, null)
            tile.setName(String.format("%s — Tile [%.0f,%.0f]", baseAnn.getName(), x, y))
            addObject(tile)
            tiles << tile
        }
    }
    fireHierarchyUpdate()
    println "INFO: Created ${tiles.size()} tiles for '${baseAnn.getName()}' (inside annotation, size ≈ ${TILE_SIZE_UM} µm)."

    int nt = tiles.size(); if (nt == 0) return

    def tbx = new double[nt], tby = new double[nt], tbw = new double[nt], tbh = new double[nt]
    for (int i = 0; i < nt; i++) {
        def r = tiles[i].getROI()
        tbx[i] = r.getBoundsX(); tby[i] = r.getBoundsY()
        tbw[i] = r.getBoundsWidth(); tbh[i] = r.getBoundsHeight()
    }

    int[] hArr  = new int[nt]
    int[] piArr = new int[nt]
    int[] caArr = new int[nt]

    // Also accumulate intensity sums to compute per-tile mean cell intensities
    double[] sumR = new double[nt]; int[] nR = new int[nt]
    double[] sumG = new double[nt]; int[] nG = new int[nt]
    double[] sumB = new double[nt]; int[] nB = new int[nt]

    def binOne = { obj, int[] counterArr, String keyMean, double[] sumArr, int[] nArr ->
        def r = obj.getROI()
        double cx = r.getCentroidX(), cy = r.getCentroidY()
        for (int i = 0; i < nt; i++) {
            if (cx >= tbx[i] && cx < tbx[i] + tbw[i] &&
                cy >= tby[i] && cy < tby[i] + tbh[i]) {
                counterArr[i] = counterArr[i] + 1
                // add intensity mean if available
                double v = mval(obj.getMeasurementList(), keyMean)
                if (!Double.isNaN(v)) { sumArr[i] += v; nArr[i]++ }
                break
            }
        }
    }

    hCells.each { binOne(it, hArr,  KEY_B, sumB, nB) }
    pCells.each { binOne(it, piArr, KEY_R, sumR, nR) }
    cCells.each { binOne(it, caArr, KEY_G, sumG, nG) }

    def toRemove = []
    def bgPairs = new ArrayList()  // pairs of [tile, bgAnn]

    for (int i = 0; i < nt; i++) {
        def tileROI = tiles[i].getROI()

        // Compute actual tile area & area fraction relative to intended full tile
        double tileAreaPx  = areaOf(tileROI)
        double tileAreaUm2 = tileAreaPx * umPerPx * umPerPx
        double areaFrac    = (fullTileAreaUm2 > 0) ? Math.min(1.0, tileAreaUm2 / fullTileAreaUm2) : 1.0
        int minPerThisTile = Math.max(1, (int)Math.round(MIN_PER_CHANNEL * areaFrac))

        // ---------- Unions & PI/CAL area (inside tile) ----------
        def unionOp = (RoiTools.CombineOp.values()*.name().contains('UNION')) ?
                RoiTools.CombineOp.valueOf('UNION') : RoiTools.CombineOp.ADD

        def piUnion = null
        def calUnion = null
        def allUnion = null  // union of H, PI, CAL (for occupied cell area)

        pCells.each { p ->
            def inter = RoiTools.combineROIs(p.getROI(), tileROI, RoiTools.CombineOp.INTERSECT)
            if (areaOf(inter) > 0.0) {
                piUnion = (piUnion == null) ? inter : RoiTools.combineROIs(piUnion, inter, unionOp)
                allUnion = (allUnion == null) ? inter : RoiTools.combineROIs(allUnion, inter, unionOp)
            }
        }
        cCells.each { c ->
            def inter = RoiTools.combineROIs(c.getROI(), tileROI, RoiTools.CombineOp.INTERSECT)
            if (areaOf(inter) > 0.0) {
                calUnion = (calUnion == null) ? inter : RoiTools.combineROIs(calUnion, inter, unionOp)
                allUnion = (allUnion == null) ? inter : RoiTools.combineROIs(allUnion, inter, unionOp)
            }
        }
        hCells.each { h ->
            def inter = RoiTools.combineROIs(h.getROI(), tileROI, RoiTools.CombineOp.INTERSECT)
            if (areaOf(inter) > 0.0) {
                allUnion = (allUnion == null) ? inter : RoiTools.combineROIs(allUnion, inter, unionOp)
            }
        }

        double areaPI_um2   = areaOf(piUnion)  * umPerPx * umPerPx
        double areaCAL_um2  = areaOf(calUnion) * umPerPx * umPerPx
        double occCell_um2  = areaOf(allUnion) * umPerPx * umPerPx   // total occupied cell area in tile

        // PI fraction and ratio
        double denom  = areaPI_um2 + areaCAL_um2
        double piFrac = (denom > 0.0) ? (areaPI_um2 / denom) : Double.NaN
        double ratioPIoverCAL = (areaCAL_um2 > 0.0) ? (areaPI_um2 / areaCAL_um2) : Double.NaN

        // ---------- BACKGROUND mask ----------
        def hasSubtract = RoiTools.CombineOp.values()*.name().contains('SUBTRACT')
        def subtractOp  = hasSubtract ? RoiTools.CombineOp.valueOf('SUBTRACT') : null

        def bgROI = (allUnion == null) ? tileROI :
                    (hasSubtract ? RoiTools.combineROIs(tileROI, allUnion, subtractOp) : null)

        double bgAreaPx  = areaOf(bgROI)
        double bgAreaUm2 = bgAreaPx * umPerPx * umPerPx

        if (bgROI != null && bgAreaPx > 0.0) {
            def bgAnn = PathObjects.createAnnotationObject(bgROI, null)
            bgAnn.setName(String.format("%s — Tile BG [%.0f,%.0f]", baseAnn.getName(), tbx[i], tby[i]))
            addObject(bgAnn)
            bgPairs << [tile: tiles[i], bg: bgAnn]
        } else if (!hasSubtract && allUnion != null) {
            println "WARN: SUBTRACT op not available; skipping background for a tile under '${baseAnn.getName()}'."
        }

        // ---------- Keep/drop rule (AREA-NORMALIZED) ----------
        boolean keep = (hArr[i]  >= minPerThisTile) ||
                       (piArr[i] >= minPerThisTile) ||
                       (caArr[i] >= minPerThisTile)

        // ---------- Stamp per-tile metrics now (some values filled later) ----------
        def ml = tiles[i].getMeasurementList()
        ml.put('Tile area (µm²)',                 tileAreaUm2)
        ml.put('Tile area fraction of full',      areaFrac)
        ml.put('Tile count Hoechst',              (double)hArr[i])
        ml.put('Tile count PI',                   (double)piArr[i])
        ml.put('Tile count Calcein',              (double)caArr[i])
        ml.put('Tile union area PI (µm²)',        areaPI_um2)
        ml.put('Tile union area CAL (µm²)',       areaCAL_um2)
        ml.put('Tile occupied cell area (µm²)',   occCell_um2)
        ml.put('Tile PI fraction',                piFrac)
        ml.put('Tile PI/CAL area ratio',          ratioPIoverCAL)
        ml.put('Tile passes filter (any channel ≥ min)', keep ? 1.0 : 0.0)
        ml.put('Tile BG area (µm²)',              bgAreaUm2)

        // Placeholders for BG means & cell means & ratios (filled after BG measurement)
        ml.put('Tile BG mean PI',            Double.NaN)
        ml.put('Tile BG mean Calcein',       Double.NaN)
        ml.put('Tile BG mean Hoechst',       Double.NaN)
        ml.put('Tile mean cell PI',          (nR[i] > 0 ? (sumR[i]/nR[i]) : Double.NaN))
        ml.put('Tile mean cell Calcein',     (nG[i] > 0 ? (sumG[i]/nG[i]) : Double.NaN))
        ml.put('Tile mean cell Hoechst',     (nB[i] > 0 ? (sumB[i]/nB[i]) : Double.NaN))
        ml.put('Tile cell/BG ratio PI',      Double.NaN)
        ml.put('Tile cell/BG ratio Calcein', Double.NaN)
        ml.put('Tile cell/BG ratio Hoechst', Double.NaN)

        // Update tile name with quick summary
        String fracStr  = Double.isNaN(piFrac) ? "NaN" : String.format("%.2f", piFrac)
        String ratioStr = Double.isNaN(ratioPIoverCAL) ? "NaN" : String.format("%.2f", ratioPIoverCAL)
        tiles[i].setName(String.format("%s — Tile H=%d, PI=%d, CAL=%d, PIfrac=%s, Ratio=%s",
                baseAnn.getName(), hArr[i], piArr[i], caArr[i], fracStr, ratioStr))

        if (!keep) toRemove << tiles[i]
    }

    // Batch measure BG means on all BG annotations we created
    def bgAnnsAll = bgPairs.collect { it.bg }
    if (!bgAnnsAll.isEmpty()) {
        measureBGMeansRGB_on(bgAnnsAll)
        // Stamp the BG means & compute ratios on tiles using the saved pairs
        bgPairs.each { pair ->
            def t = pair.tile
            def bga = pair.bg
            def mlb = bga.getMeasurementList()
            double r = pickMean(mlb, 'red')
            double g = pickMean(mlb, 'green')
            double b = pickMean(mlb, 'blue')

            def mlt = t.getMeasurementList()
            mlt.put('Tile BG mean PI',      r)  // Red -> PI
            mlt.put('Tile BG mean Calcein', g)  // Green -> Calcein
            mlt.put('Tile BG mean Hoechst', b)  // Blue -> Hoechst

            double cellR = mval(mlt, 'Tile mean cell PI')
            double cellG = mval(mlt, 'Tile mean cell Calcein')
            double cellB = mval(mlt, 'Tile mean cell Hoechst')

            mlt.put('Tile cell/BG ratio PI',      (r > 0 && Double.isFinite(cellR)) ? (cellR / r) : Double.NaN)
            mlt.put('Tile cell/BG ratio Calcein', (g > 0 && Double.isFinite(cellG)) ? (cellG / g) : Double.NaN)
            mlt.put('Tile cell/BG ratio Hoechst', (b > 0 && Double.isFinite(cellB)) ? (cellB / b) : Double.NaN)

            removeObjectAndDescendants(bga)     // clean up BG objects
        }
        fireHierarchyUpdate()
    }

    if (!toRemove.isEmpty()) {
        def clsRemoved = getPathClass("Tile - Removed", (0xFF<<24)|(158<<16)|(158<<8)|158) // gray
        toRemove.each { t ->
            t.setPathClass(clsRemoved)
            // keep the measurement stamped earlier:
            // 'Tile passes filter (any channel ≥ min)' = 0
        }
        println "INFO: Marked ${toRemove.size()} tiles as 'Removed' (kept for export)."
    } else {
    println "INFO: All tiles passed the OR rule."
    }
fireHierarchyUpdate()
}

// Run tiles on processed bases
getAnnotationObjects()
    .findAll { it.hasROI() && (PROCESS_ALL_ANNOTATIONS || (it.getName() == ONLY_ANN_NAME)) }
    .each { createTilesAndFilter(it) }


// ====== Color tiles by ABSOLUTE PI FRACTION (Alive / Mixed / Dead), skipping removed tiles ======
def colorTilesByAbsolute = { boolean processAll, String onlyName, double lowMax, double highMin ->
    final int COL_ALIVE = (0xFF<<24)|( 76<<16)|(175<<8)| 80   // green
    final int COL_MIXED = (0xFF<<24)|(255<<16)|(193<<8)|  7   // amber
    final int COL_DEAD  = (0xFF<<24)|(229<<16)|( 57<<8)| 53   // red

    def clsAlive = getPathClass(String.format("Tile - Alive (PIfrac<%.2f)", lowMax), COL_ALIVE)
    def clsMixed = getPathClass("Tile - Mixed",                                    COL_MIXED)
    def clsDead  = getPathClass(String.format("Tile - Dead (PIfrac≥%.2f)", highMin), COL_DEAD)

    def bases = getAnnotationObjects().findAll { it.hasROI() }
    if (!processAll) {
        def a = bases.find { it.getName() == onlyName }
        bases = a ? [a] : []
    }
    if (bases.isEmpty()) return

    for (baseAnn in bases) {
        // Collect tiles under this base, then filter out removed ones
        def tilesHere = getAnnotationObjects().findAll { obj ->
            def nm = (obj.getName() ?: "")
            nm.startsWith(baseAnn.getName() + " — Tile") || nm.startsWith(baseAnn.getName() + " - Tile")
        }

        // Keep only tiles that passed the min-count filter AND are not classed as "Tile - Removed"
        tilesHere = tilesHere.findAll { t ->
            def clsName = t.getPathClass()?.getName() ?: ""
            if (clsName == "Tile - Removed") return false
            def ml = t.getMeasurementList()
            def v = (ml != null ? ml.get('Tile passes filter (any channel ≥ min)') : null)
            double pass = (v instanceof Number) ? (v as double) : Double.NaN
            return Double.isFinite(pass) && pass == 1.0
        }

        if (tilesHere.isEmpty()) {
            println "INFO: No kept tiles to color under '${baseAnn.getName()}'."
            continue
        }

        int nAlive=0, nMixed=0, nDead=0
        for (t in tilesHere) {
            def ml = t.getMeasurementList()
            double aPI  = (ml?.get('Tile union area PI (µm²)')  instanceof Number) ? (ml.get('Tile union area PI (µm²)')  as double) : Double.NaN
            double aCAL = (ml?.get('Tile union area CAL (µm²)') instanceof Number) ? (ml.get('Tile union area CAL (µm²)') as double) : Double.NaN
            double frac = (ml?.get('Tile PI fraction') instanceof Number) ? (ml.get('Tile PI fraction') as double) :
                          ((aPI + aCAL) > 0.0 ? aPI/(aPI+aCAL) : Double.NaN)

            if (!Double.isFinite(frac)) {
                if (aCAL <= 0.0 && aPI > 0.0) { t.setPathClass(clsDead);  nDead++  }
                else if (aPI <= 0.0 && aCAL > 0.0) { t.setPathClass(clsAlive); nAlive++ }
                else { t.setPathClass(clsMixed); nMixed++ }
                continue
            }

            if (frac < lowMax) { t.setPathClass(clsAlive); nAlive++ }
            else if (frac >= highMin) { t.setPathClass(clsDead); nDead++ }
            else { t.setPathClass(clsMixed); nMixed++ }
        }
        fireHierarchyUpdate()
        println String.format(
            "INFO: Colored kept tiles for '%s' -> alive=%d, mixed=%d, dead=%d (alive<%.2f, dead≥%.2f)",
            baseAnn.getName(), nAlive, nMixed, nDead, lowMax, highMin
        )
    }
}

colorTilesByAbsolute(PROCESS_ALL_ANNOTATIONS, ONLY_ANN_NAME, PI_FRAC_ALIVE_MAX, PI_FRAC_DEAD_MIN)

