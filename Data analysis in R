# 3) Compute fractions on kept tiles
coverage_df <- tiles_kept_only %>%
  dplyr::transmute(
    tile_area_um2 = `Tile area (µm²)`,
    bg_area_um2   = `Tile BG area (µm²)`,
    cell_area_um2 = pmax(tile_area_um2 - bg_area_um2, 0),
    Fraction      = dplyr::if_else(tile_area_um2 > 0, cell_area_um2 / tile_area_um2, NA_real_),
    Metric        = "Cell coverage"
  )

bgfrac_df <- tiles_kept_only %>%
  dplyr::transmute(
    tile_area_um2 = `Tile area (µm²)`,
    bg_area_um2   = `Tile BG area (µm²)`,
    Fraction      = dplyr::if_else(tile_area_um2 > 0, bg_area_um2 / tile_area_um2, NA_real_),
    Metric        = "Background fraction"
  )

# 4) Combine & clean
cov_long <- dplyr::bind_rows(coverage_df, bgfrac_df) %>%
  dplyr::filter(is.finite(Fraction)) %>%
  dplyr::mutate(
    Fraction = pmin(pmax(Fraction, 0), 1),  # clamp to [0,1] just in case
    Metric   = factor(Metric, levels = c("Cell coverage", "Background fraction"))
  )

if (nrow(cov_long) == 0) {
