# --- Helper: reassign triple 'Several' H-cells to H+PI or H+CAL ----------
choose_pair <- function(n_pi, n_cal, r_mean, g_mean) {
  r_ok  <- is.finite(n_pi)  && n_pi  > 0
  g_ok  <- is.finite(n_cal) && n_cal > 0
  if (r_ok && !g_ok) return("H + PI")
  if (!r_ok && g_ok) return("H + CAL")
  if (is.finite(r_mean) && is.finite(g_mean)) {
    if (r_mean >= g_mean) "H + PI" else "H + CAL"
  } else {
    "H + PI"  # fallback
  }
}

