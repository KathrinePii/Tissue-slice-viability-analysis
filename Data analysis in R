# --- Non-overlapping outside labels for small slices -------------------------
thr_small <- 5     # % threshold for outside labels
min_gap   <- 3     # minimum vertical separation between labels in % points

# --- geometry for a pie made with geom_col(width = 1) ---
pie_x_center <- 1.0
pie_width    <- 1.0
r_inner      <- pie_x_center - pie_width/2   # 0.5
r_outer      <- pie_x_center + pie_width/2   # 1.5


pie_labs <- cat_df %>%
  arrange(desc(Category)) %>%
  mutate(
    lbl    = paste0(round(Percent, 1), "%"),
    y_mid  = cumsum(Percent) - Percent/2,
    small  = Percent < thr_small,
    x_start = r_outer,          # start at outer rim
    x_tick  = r_outer + 0.10,   # short line outside
    x_label = r_outer + 0.22    # text a bit further out
  )

# De-overlap only the 'small' labels by enforcing a minimum spacing along y
spread_small_labels <- function(y, gap = 3, y_min = 0, y_max = 100) {
  y <- sort(y)
  if (!length(y)) return(y)
  ys <- y
  for (i in 2:length(ys)) {
    if (ys[i] - ys[i-1] < gap) ys[i] <- ys[i-1] + gap
  }
  ys <- pmin(ys, y_max)                # clamp at top
  # optional: push back down if we ran into the ceiling
  for (i in (length(ys)-1):1) {
    if (ys[i+1] - ys[i] < gap) ys[i] <- ys[i+1] - gap
  }
  ys <- pmax(ys, y_min)                # clamp at bottom
  # put back in original order
  out <- numeric(length(y))
  out[order(order(y))] <- ys
  out
}

small_idx <- which(pie_labs$small)
pie_labs$y_out <- pie_labs$y_mid
if (length(small_idx)) {
  pie_labs$y_out[small_idx] <- spread_small_labels(
    pie_labs$y_mid[small_idx],
    gap = min_gap,
    y_min = 0 + 1.0,     # keep a little margin from 0%
    y_max = 100 - 1.0    # ...and from 100%
  )
}

